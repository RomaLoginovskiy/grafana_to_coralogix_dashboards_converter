{
  "grafana": {
    "region": "eu1",
    "folders": []
  },
  "coralogix": {
    "region": "eu1",
    "folderId": "",
    "isLocked": false,
    "migrateFolderStructure": false
  },
  "credentials": {
    "grafanaApiKey": "glsa_replace_with_real_grafana_key",
    "cxApiKey": "cxtp_replace_with_real_cx_key"
  },
  "migration": {
    "checkpointFile": "migration-checkpoint.integration.json",
    "reportFile": "migration-report.integration.txt",
    "backupFile": "grafana-backup.integration.zip",
    "maxRetries": 5,
    "initialRetryDelaySeconds": 2,
    "multiLuceneMerge": {
      "allowlistedWidgetTypes": [
        "barchart",
        "timeseries",
        "piechart",
        "status-history"
      ]
    }
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": {
      "File": {
        "Enabled": true,
        "Path": "logs/grafana-to-cx-.json",
        "RollingInterval": "Day",
        "Formatter": "Json"
      },
      "Otlp": {
        "Enabled": true,
        "Endpoint": "http://localhost:4317",
        "Protocol": "Grpc"
      }
    },
    "Enrich": [ "FromLogContext" ],
    "Properties": {
      "Service": "grafana-to-cx-cli"
    }
  }
}
